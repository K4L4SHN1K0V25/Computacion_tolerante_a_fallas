      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  // Extraemos el texto de la IA y lo pasamos a minúsculas para comparar\n  const aiResponse = (item.json.message?.text || \"\").toLowerCase();\n\n  // Validamos si la respuesta contiene \"linkedin\"\n  if (aiResponse.includes('linkedin')) {\n    item.json.category = \"LinkedIn\";\n    item.json.isTarget = true;\n  } else {\n    // Si es cualquier otra cosa (o error), cae en \"Otro\"\n    item.json.category = \"Otro\";\n    item.json.isTarget = false;\n  }\n}\n\nreturn $input.all();"
      },
